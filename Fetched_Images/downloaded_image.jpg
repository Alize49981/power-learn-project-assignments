		<style type="text/css" id="wp-custom-css">
			/* header-top */

@keyframes colorChange {
  0% {
    background-image: linear-gradient(to right, #28ad34, #fe9f43); /* Primary to Secondary */
  }
  50% {
    background-image: linear-gradient(to right, #fe9f43, #28ad34); 
  }
  100% {
    background-image: linear-gradient(to right, #28ad34, #fe9f43); /* Back to Primary */
  }
}

.header-top .container {
  animation: colorChange 6s infinite; /* Apply animation for 6 seconds loop */
}

/* header-top ends */		</style>
